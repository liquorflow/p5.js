{
  "name": "p5",
  "version": "2.0.0",
  "description": "p5.js is a client-side JS platform that empowers artists, designers, students, and anyone to learn to code and express themselves creatively on the web.",
  "main": "src/app.js",
  "module": "src/app.js",
  "homepage": "https://p5js.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/processing/p5.js.git"
  },
  "license": "LGPL-2.1",
  "bugs": {
    "url": "https://github.com/processing/p5.js/issues"
  },
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c --watch",
    "dev": "vite",
    "docs": "node docs/build.js",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@vitest/coverage-v8": "^1.2.0",
    "eslint": "^8.56.0",
    "rollup": "^4.9.6",
    "vite": "^5.0.12",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "opentype.js": "^1.3.4"
  },
  "keywords": [
    "p5",
    "p5js",
    "processing",
    "canvas",
    "creative-coding",
    "graphics",
    "visualization",
    "art",
    "generative"
  ],
  "files": [
    "src",
    "lib",
    "types"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
